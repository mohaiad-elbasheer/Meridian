POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://meridian:change-me@db:5432/meridian

# IMF PortWatch ArcGIS FeatureServer query endpoints (the "Access API" GeoService URLs
# from https://portwatch.imf.org/pages/data-and-methodology, org weJ1QsnbMYJlCHdG).
# Pinned 2026-07-03 from the PortWatch ArcGIS Online organization. NOTE: outbound access
# to *.arcgis.com was blocked in the environment where these were pinned, so they could
# not be live-verified there. Verify before first run:  python -m meridian_ingest.verify_endpoints
PORTWATCH_CHOKEPOINTS_URL=https://services9.arcgis.com/weJ1QsnbMYJlCHdG/arcgis/rest/services/Daily_Chokepoints_Data/FeatureServer/0/query
PORTWATCH_PORTS_URL=https://services9.arcgis.com/weJ1QsnbMYJlCHdG/arcgis/rest/services/Daily_Trade_Data/FeatureServer/0/query

COMTRADE_API_KEY=            # free key from comtradeapi.un.org
